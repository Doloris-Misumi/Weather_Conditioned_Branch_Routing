ninja_required_version = 1.3
cxx = /home/hongsheng/miniconda3/envs/rl_3dod/bin/x86_64-conda-linux-gnu-c++
nvcc = /home/hongsheng/miniconda3/envs/rl_3dod/bin/nvcc

cflags = -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -Wstrict-prototypes -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -pipe -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -pipe -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /home/hongsheng/miniconda3/envs/rl_3dod/include -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/hongsheng/miniconda3/envs/rl_3dod/include -fPIC -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include/TH -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include/THC -I/home/hongsheng/miniconda3/envs/rl_3dod/include -I/home/hongsheng/miniconda3/envs/rl_3dod/include/python3.8 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=sort_vertices -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_cflags = -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include/TH -I/home/hongsheng/miniconda3/envs/rl_3dod/lib/python3.8/site-packages/torch/include/THC -I/home/hongsheng/miniconda3/envs/rl_3dod/include -I/home/hongsheng/miniconda3/envs/rl_3dod/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=sort_vertices -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -ccbin /home/hongsheng/miniconda3/envs/rl_3dod/bin/x86_64-conda-linux-gnu-cc -std=c++14
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags



build /home/hongsheng/RL_3DOD/utils/Rotated_IoU/cuda_op/build/temp.linux-x86_64-3.8/sort_vert.o: compile /home/hongsheng/RL_3DOD/utils/Rotated_IoU/cuda_op/sort_vert.cpp
build /home/hongsheng/RL_3DOD/utils/Rotated_IoU/cuda_op/build/temp.linux-x86_64-3.8/sort_vert_kernel.o: cuda_compile /home/hongsheng/RL_3DOD/utils/Rotated_IoU/cuda_op/sort_vert_kernel.cu





